# Root-level environment reference — copy to each service as needed.
# See web/.env.local.example and geometry/.env.example for service configs.

# Supabase project (get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Geometry service
GEOMETRY_SERVICE_URL=http://localhost:8001
GEOMETRY_SERVICE_API_KEY=dev-secret

# Stripe billing (future launch — not required for development)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID_MONTHLY=price_...
STRIPE_PRO_PRICE_ID_YEARLY=price_...
