# Geometry service environment
# Copy to .env and fill in values.

# Shared secret with the web app (set GEOMETRY_SERVICE_API_KEY in web/.env.local)
API_KEY=dev-secret

# Supabase service role — used for storage writes (export bundles)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Log level
LOG_LEVEL=INFO
